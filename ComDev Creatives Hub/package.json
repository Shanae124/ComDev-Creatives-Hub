{
  "name": "comdev-creatives-hub",
  "version": "1.0.0",
  "description": "Community Development Creative Learning Platform - Social Media Marketing & Cricut Design",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cross-env PORT=5000 node server-mock.js",
    "client": "cross-env PORT=3000 next dev -p 3000",
    "build": "next build",
    "start": "node server-mock.js",
    "init-db": "node scripts/init-database.js"
  },
  "keywords": ["learning", "social-media", "cricut", "community"],
  "author": "Community Development Department",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express-validator": "^7.0.1",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "typescript": "^5.3.3",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.33",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3",
    "cross-env": "^7.0.3"
  }
}
